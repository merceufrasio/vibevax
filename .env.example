# TMDB API credentials
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# See https://developer.themoviedb.org/reference/intro/authentication
#
# The `EXPO_PUBLIC_` prefix exposes these values to the client at build time
# via Expo's standard env loading.

# TMDB v3 API key. Used as `api_key` query parameter when present.
EXPO_PUBLIC_TMDB_API_KEY=

# TMDB v4 read access bearer token. Used as `Authorization: Bearer <token>`
# when no v3 api key is set.
EXPO_PUBLIC_TMDB_BEARER_TOKEN=

# Subdl.com API key for online subtitle search.
# Register free at https://subdl.com/panel/register
EXPO_PUBLIC_SUBDL_API_KEY=
